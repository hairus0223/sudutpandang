{
  "name": "sudut-pandang-kiosk",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5180 && electron src/main.js",
    "build": "vite build",
    "build:main": "mkdirp dist && copy src\\main.js dist\\main.js && copy src\\preload.js dist\\preload.js",
    "build:renderer": "esbuild src/renderer/main.jsx --bundle --outfile=src/renderer/bundle.js --platform=browser --format=iife --jsx=automatic --sourcemap"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "electron": "^33.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "mkdirp": "^3.0.1"
  }
}
